ENV=dev
LOG_LEVEL=INFO

API_TIMEOUT_SECONDS=30

LOCAL_DATA_DIR=./data
DEAD_LETTER_DIR=./data/dead_letter

GCP_PROJECT_ID=your-gcp-project
GCP_LOCATION=US
GCS_BUCKET=your-raw-bucket
GCS_RAW_PREFIX=raw

BQ_RAW_DATASET=analytics_raw
BQ_STAGING_DATASET=analytics_staging
BQ_MART_DATASET=analytics_mart
WORLD_BANK_RAW_TABLE=world_bank_indicator
OPEN_METEO_RAW_TABLE=open_meteo_response

API_TOKEN=
# Production: inject `API_TOKEN` from Secret Manager via Cloud Run Job `--set-secrets`.

WORLD_BANK_BASE_URL=https://api.worldbank.org/v2
WORLD_BANK_INDICATOR_IDS=SP.POP.TOTL,NY.GDP.MKTP.CD
WORLD_BANK_PAGE_SIZE=20000

OPEN_METEO_FORECAST_BASE_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_BASE_URL=https://archive-api.open-meteo.com/v1
OPEN_METEO_HOURLY_VARIABLES=temperature_2m,precipitation,wind_speed_10m
OPEN_METEO_LOCATIONS=london:51.5072:-0.1276;new_york:40.7128:-74.0060
OPEN_METEO_TIMEZONE=UTC
OPEN_METEO_ARCHIVE_DAYS=7
OPEN_METEO_FORECAST_DAYS=3
OPEN_METEO_ENABLE_FORECAST=true
OPEN_METEO_ENABLE_ARCHIVE=true
